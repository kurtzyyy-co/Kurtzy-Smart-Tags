{
  "entities": {
    "profile": {
      "title": "Smart Tag Profile",
      "description": "A smart dynamic tag profile for a customer containing contact info, social links, and layout customization.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "The unique slug/identifier of the profile (e.g., 'profile-1')"
        },
        "name": {
          "type": "string",
          "description": "Full name of the customer or business"
        },
        "title": {
          "type": "string",
          "description": "Job title or subtitle"
        },
        "company": {
          "type": "string",
          "description": "Company name"
        },
        "bio": {
          "type": "string",
          "description": "Short bio or business introduction"
        },
        "phone": {
          "type": "string",
          "description": "Contact phone number"
        },
        "email": {
          "type": "string",
          "description": "Contact email address"
        },
        "website": {
          "type": "string",
          "description": "Personal or company website URL"
        },
        "socials": {
          "type": "object",
          "description": "Map of social handles/URLs (twitter, linkedin, github, instagram, facebook, youtube)"
        },
        "theme": {
          "type": "string",
          "description": "Visual theme identifier (e.g., 'modern', 'brutalist', 'neon', 'classic')"
        },
        "accentColor": {
          "type": "string",
          "description": "Custom color hex or code"
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL of the avatar/logo"
        },
        "clicks": {
          "type": "number",
          "description": "Total scans/clicks analytics count"
        },
        "customFields": {
          "type": "array",
          "description": "List of key-value custom details"
        },
        "createdBy": {
          "type": "string",
          "description": "The UID of the admin user who created this profile"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp"
        }
      },
      "required": ["id", "name", "createdBy", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/profiles/{profileId}": {
      "schema": "profile",
      "description": "Smart tag customer profiles indexed by their unique slug ID."
    }
  }
}
